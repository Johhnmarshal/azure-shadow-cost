# Azure Shadow Cost — local development environment.
# Copy to .env (or export in shell). In Azure App Service these come from
# appSettings, set by main.bicep.

# Subscription the detectors operate on. The MI / your az login must have Reader on it.
TARGET_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Comma-separated mandatory tag keys. Drives the Visibility Gap calc.
REQUIRED_TAGS=Owner,CostCenter,Environment,Application

# Reporting currency. Set to "auto" (default) to detect from a Cost Management
# probe at startup. Set to a 3-letter ISO code (e.g., GBP) to force a glyph.
REPORTING_CURRENCY=auto

# Cache TTL for ARG / Cost Management responses (seconds). 600 = 10 min.
CACHE_TTL_SECONDS=600

# Set to "true" to skip Azure calls and serve deterministic mock findings.
USE_MOCK_DATA=true

# ---------------------------------------------------------------------------
# Peak-rightsizing thresholds (PR3). Values overridable per-run via the SPA's
# Settings panel; these env vars seed the defaults at startup. The Conservative
# profile (defaults) is safe for spiky / batch workloads.
# ---------------------------------------------------------------------------
AZSHC_T_DS_CPU_P95=40    # downsize candidate if P95 CPU < this
AZSHC_T_DS_MEM_P95=50    # downsize candidate if P95 mem-used < this
AZSHC_T_DS_CPU_P99=50    # HIGH confidence if P99 CPU also under this
AZSHC_T_DS_MEM_P99=60    # HIGH confidence if P99 mem also under this
AZSHC_T_US_CPU_P95=80    # upsize warning if P95 CPU >= this
AZSHC_T_US_MEM_P95=85    # upsize warning if P95 mem-used >= this
AZSHC_T_MIN_COV=0.80     # minimum metric coverage (0..1) for a verdict

# ---------------------------------------------------------------------------
# RI / Savings-Plan refund buffer (PR4). Operator-set cancellation exposure
# cap in tenant currency. NO DEFAULT — the SPA prompts if unset, and the
# rollup Finding is suppressed from /api/findings until you opt in.
# Microsoft's current cancellation fee is 12% of annual commit; a 5,000
# buffer covers ~41,000 of safely-cancellable annual commit.
# ---------------------------------------------------------------------------
# AZSHC_REFUND_BUFFER=5000
